{
  "name": "attendance-payroll-app",
  "version": "1.2.0",
  "description": "نظام إدارة حضور ورواتب الموظفين",
  "main": "main.js",
  "author": "Sir/Saqr",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "build:portable": "electron-builder --win portable --ia32",
    "build:setup": "electron-builder --win nsis --ia32",
    "build:win": "electron-builder --win portable nsis --ia32"
  },
  "build": {
    "appId": "com.shiftly.attendance",
    "productName": "Shiftly",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "db/**/*",
      "node_modules/**/*",
      "!node_modules/.cache/**/*",
      "!dist/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": ["ia32"]
        },
        {
          "target": "nsis",
          "arch": ["ia32"]
        }
      ],
      "icon": "src/icon.ico",
      "requestedExecutionLevel": "requireAdministrator"
    },
    "portable": {
      "artifactName": "Shiftly-Portable-ia32.exe"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Shiftly",
      "artifactName": "Shiftly-Setup-ia32.exe",
      "language": "1033",
      "installerLanguages": ["en_US", "ar_SA"],
      "displayLanguageSelector": true,

      "unicode": true,
      "uninstallDisplayName": "Shiftly — نظام إدارة الحضور"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ]
  },
  "dependencies": {
    "better-sqlite3": "8.7.0"
  },
  "devDependencies": {
    "electron": "22.3.27",
    "electron-builder": "24.9.1",
    "electron-rebuild": "3.2.9"
  }
}
